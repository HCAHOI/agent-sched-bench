# Copy to .env and edit for the active environment.

MODEL_PATH=meta-llama/Llama-3.1-8B-Instruct
VLLM_API_BASE=http://localhost:8000/v1
VLLM_METRICS_URL=http://localhost:8000/metrics
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_SPEC=vllm==0.10.2
VLLM_HEALTH_TIMEOUT_S=180
VLLM_LOG_PATH=results/processed/vllm_server.log
VLLM_REPORT_PATH=results/processed/vllm_server_report.json
VLLM_PREEMPTION_MODE=recompute
VLLM_MAX_NUM_SEQS=256
VLLM_PREEMPTION_REPORT_PATH=results/processed/vllm_preemption_report.json
VLLM_SCHEDULER_HOOK=1
VLLM_SCHEDULER_HOOK_REPORT_PATH=results/processed/vllm_scheduler_hook_report.json
CONTINUUM_API_BASE=http://localhost:8001/v1
CONTINUUM_METRICS_URL=http://localhost:8001/metrics
CONTINUUM_PORT=8001
CONTINUUM_REPO_URL=https://github.com/Hanchenli/vllm-continuum.git
CONTINUUM_REF=REPLACE_WITH_COMMIT_OR_TAG
CONTINUUM_USE_CPU_OFFLOAD=0
CONTINUUM_LMCACHE_CPU_GIB=200
CONTINUUM_LMCACHE_SPEC=lmcache==0.3.7
THUNDERAGENT_API_BASE=http://localhost:9000/v1
THUNDERAGENT_PORT=9000
THUNDERAGENT_REPO_URL=https://github.com/ThunderAgent-org/ThunderAgent.git
THUNDERAGENT_REF=REPLACE_WITH_COMMIT_OR_TAG
THUNDERAGENT_BACKENDS=http://127.0.0.1:8000
THUNDERAGENT_METRICS_URL=http://localhost:9000/metrics
THUNDERAGENT_PROFILE_DIR=results/processed/thunderagent_profiles
THUNDERAGENT_LOG_PATH=results/processed/thunderagent.log
THUNDERAGENT_REPORT_PATH=results/processed/thunderagent_report.json
DUCKDUCKGO_RATE_LIMIT_QPS=1
