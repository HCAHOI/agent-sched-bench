# Copy to .env and edit for the active cloud provider.

# Built-in providers use their provider-specific key env var.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=

# Optional OpenAI-compatible gateway override.
OPENAI_API_BASE=https://api.openai.com/v1
MODEL=z-ai/glm-5.1

# Conservative DuckDuckGo search throttling for web tools.
DUCKDUCKGO_RATE_LIMIT_QPS=1
