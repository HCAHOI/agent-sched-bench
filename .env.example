# Copy to .env and edit for the active environment.

MODEL_PATH=/data/models/Llama-3.1-8B-Instruct
VLLM_API_BASE=http://localhost:8000/v1
VLLM_METRICS_URL=http://localhost:8000/metrics
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_SPEC=vllm>=0.8,<0.9
VLLM_HEALTH_TIMEOUT_S=180
VLLM_LOG_PATH=results/processed/vllm_server.log
VLLM_REPORT_PATH=results/processed/vllm_server_report.json
THUNDERAGENT_API_BASE=http://localhost:9000/v1
DUCKDUCKGO_RATE_LIMIT_QPS=1
